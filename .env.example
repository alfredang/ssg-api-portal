SSG_API_BASE_URL=https://public-api.ssg-wsg.sg
SSG_CLIENT_ID=your_client_id_here
SSG_CLIENT_SECRET=your_client_secret_here
PORT=3001

# ── App environment / deployment (Coolify) ───────────────────────
# Set NODE_ENV=production on the remote (Coolify) deployment.
# NODE_ENV=production

# ── Per-user defaults storage (file-based — replaces Firestore) ──
# Defaults are saved to a JSON file under this directory. On Coolify,
# mount a persistent volume here so they survive redeploys.
# DATA_DIR=/app/server/data

# ── Authentication ───────────────────────────────────────────────
# Localhost requires NO login by default. Remote (NODE_ENV=production)
# requires Google sign-in. Override explicitly with AUTH_DISABLED=true|false.
# AUTH_DISABLED=false
SESSION_SECRET=change-me-to-a-long-random-string
# Google OAuth 2.0 credentials (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Must match an Authorized redirect URI in the Google OAuth client, e.g.
# https://your-domain.com/auth/google/callback
GOOGLE_CALLBACK_URL=https://your-domain.com/auth/google/callback

SSG_CERT_API_BASE_URL=https://api.ssg-wsg.sg

# ── SSG mTLS certificates (SECRETS — never commit; keep in .env / a volume) ──
# Two ways to supply each cert set (the *_FILE path wins if both are set):
#   A) Persistent storage (recommended on Coolify): point at PEM files on a
#      mounted volume — real newlines, no \n escaping:
#        CERT_1_CERT_FILE=/app/server/.cert/skilleto_cert.pem
#        CERT_1_KEY_FILE=/app/server/.cert/skilleto_key.pem
#        CERT_1_ENCRYPTION_KEY_FILE=/app/server/.cert/skilleto_enc.key
#   B) Inline env vars (below). Multiline PEM with literal \n is normalised.

# Certificate 1 (SKILLETO)
CERT_1_NAME=SKILLETO
CERT_1_CERT="-----BEGIN CERTIFICATE-----\nMIIG...\n-----END CERTIFICATE-----"
CERT_1_KEY="-----BEGIN PRIVATE KEY-----\nMIIJ...\n-----END PRIVATE KEY-----"
CERT_1_ENCRYPTION_KEY="your-32-char-encryption-key-here"

# Certificate 2 (TMS 1)
# CERT_2_NAME=TMS 1
CERT_2_CERT="-----BEGIN CERTIFICATE-----\nMIIG...\n-----END CERTIFICATE-----"
CERT_2_KEY="-----BEGIN PRIVATE KEY-----\nMIIJ...\n-----END PRIVATE KEY-----"
CERT_2_ENCRYPTION_KEY="your-32-char-encryption-key-here"

# Certificate 3 (TMS 3)
# CERT_3_NAME=TMS 3
# CERT_3_CERT="-----BEGIN CERTIFICATE-----\nMIIG...\n-----END CERTIFICATE-----"
# CERT_3_KEY="-----BEGIN PRIVATE KEY-----\nMIIJ...\n-----END PRIVATE KEY-----"
# CERT_3_ENCRYPTION_KEY=your-32-character-encryption-key

# OAuth Configuration (TMS 2)
# OAUTH_CLIENT_ID=your-client-id
# OAUTH_CLIENT_SECRET=your-client-secret
